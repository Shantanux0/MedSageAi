{
  "info": {
    "name": "MedAI API",
    "_postman_id": "medai-collection-v1",
    "description": "Full API collection for MedAI backend. Steps: 1) Register, 2) Login (token auto-saved), 3) Use any protected route.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",    "value": "",                     "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Patient)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Patient\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"PATIENT\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"bloodGroup\": \"O+\",\n  \"allergies\": \"Penicillin\"\n}"
            }
          }
        },
        {
          "name": "Register (Doctor)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Sarah Smith\",\n  \"email\": \"doctor@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"DOCTOR\",\n  \"specialization\": \"Cardiology\",\n  \"licenseNumber\": \"MED-2024-001\",\n  \"hospitalAffiliation\": \"City General Hospital\"\n}"
            }
          }
        },
        {
          "name": "Register (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login → auto-saves token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    console.log('✅ Token saved:', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Patient",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/patient/profile", "host": ["{{base_url}}"], "path": ["api","patient","profile"] }
          }
        },
        {
          "name": "Get My Records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/patient/records", "host": ["{{base_url}}"], "path": ["api","patient","records"] }
          }
        },
        {
          "name": "Upload Medical Record (PDF/Image)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/patient/upload-record", "host": ["{{base_url}}"], "path": ["api","patient","upload-record"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file",       "type": "file",  "src": "",         "description": "Select a PDF or image file" },
                { "key": "reportType", "type": "text",  "value": "BLOOD_TEST" },
                { "key": "reportName", "type": "text",  "value": "CBC Report Jan 2025" },
                { "key": "visitDate",  "type": "text",  "value": "2025-01-15" }
              ]
            }
          }
        },
        {
          "name": "Get AI Health Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/patient/summary", "host": ["{{base_url}}"], "path": ["api","patient","summary"] }
          }
        },
        {
          "name": "AI Chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/patient/chat", "host": ["{{base_url}}"], "path": ["api","patient","chat"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Is my glucose level normal?\"\n}"
            }
          }
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/patient/chat/history", "host": ["{{base_url}}"], "path": ["api","patient","chat","history"] }
          }
        }
      ]
    },

    {
      "name": "Doctor",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/doctor/profile", "host": ["{{base_url}}"], "path": ["api","doctor","profile"] }
          }
        },
        {
          "name": "Get My Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/doctor/patients", "host": ["{{base_url}}"], "path": ["api","doctor","patients"] }
          }
        },
        {
          "name": "Get Patient Records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/doctor/patient/1/records", "host": ["{{base_url}}"], "path": ["api","doctor","patient","1","records"] }
          }
        },
        {
          "name": "Get AI Summary for Patient",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/doctor/patient/1/summary", "host": ["{{base_url}}"], "path": ["api","doctor","patient","1","summary"] }
          }
        }
      ]
    },

    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/admin/users", "host": ["{{base_url}}"], "path": ["api","admin","users"] }
          }
        },
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/admin/doctors", "host": ["{{base_url}}"], "path": ["api","admin","doctors"] }
          }
        },
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/admin/patients", "host": ["{{base_url}}"], "path": ["api","admin","patients"] }
          }
        },
        {
          "name": "Assign Doctor to Patient",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/admin/assign-doctor", "host": ["{{base_url}}"], "path": ["api","admin","assign-doctor"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 1\n}"
            }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/admin/deactivate/1", "host": ["{{base_url}}"], "path": ["api","admin","deactivate","1"] }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/admin/audit-logs", "host": ["{{base_url}}"], "path": ["api","admin","audit-logs"] }
          }
        }
      ]
    }

  ]
}
